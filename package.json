{
  "name": "qrl-wallet",
  "version": "1.9.0",
  "description": "QRL Wallet",
  "author": "The QRL Contributors",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.0",
    "@ledgerhq/devices": "^8.10.0",
    "@ledgerhq/hw-transport-node-hid": "^6.30.0",
    "@ledgerhq/hw-transport-webusb": "^6.30.0",
    "@theqrl/explorer-helpers": "^2.7.0",
    "@theqrl/hw-app-qrl": "^6.28.3",
    "@theqrl/nft-providers": "^1.0.1",
    "@theqrl/node-helpers": "^0.6.1",
    "@theqrl/qrl-proto-sha256": "^3.5.0",
    "@theqrl/validate-qrl-address": "^3.0.0",
    "@theqrl/wallet-helpers": "^2.1.0",
    "aes256": "^1.1.0",
    "async": "^3.2.6",
    "bech32": "^2.0.0",
    "bignumber.js": "^9.1.2",
    "browserify-aes": "^1.2.0",
    "core-js": "^3.39.0",
    "crypto-browserify": "^3.12.1",
    "crypto-js": "^4.2.0",
    "culori": "^4.0.2",
    "json-formatter-js": "^2.5.0",
    "json-stable-stringify": "^1.1.1",
    "mathjs": "^14.0.0",
    "meteor-better-storage": "^2.0.2",
    "meteor-node-stubs": "^1.2.13",
    "qrllib": "^1.2.4",
    "sha256": "^0.2.0",
    "stream-browserify": "^3.0.0",
    "tmp": "0.2.3",
    "usb": "^2.17.0",
    "vue": "^3.5.28"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theQRL/qrl-wallet.git"
  },
  "keywords": [
    "QRL",
    "blockchain"
  ],
  "bugs": {
    "url": "https://github.com/theQRL/qrl-wallet/issues"
  },
  "homepage": "https://github.com/theQRL/qrl-wallet#readme",
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@theqrl/electrify-qrl": "1.1.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.0",
    "daisyui": "^4.12.22",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-meteor": "^0.4.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-meteor": "^7.3.0",
    "node-gyp": "^12.2.0",
    "postcss": "^8.5.0",
    "run-script-os": "^1.1.6",
    "snyk": "^1.1295.0",
    "tailwindcss": "^3.4.18"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./public/tailwind.css -o ./public/tailwind-output.css",
    "build:css:watch": "tailwindcss -i ./public/tailwind.css -o ./public/tailwind-output.css --watch",
    "audit:migration": "node .scripts/migration-audit.js",
    "start": "meteor",
    "dev": "concurrently \"npm run build:css:watch\" \"meteor\"",
    "test": "echo null",
    "postinstall": "node .scripts/patch-ledger-exports.js",
    "snyk-protect": "snyk protect",
    "prepare": "npm run snyk-protect",
    "cleanDist": "run-script-os",
    "cleanDist:darwin": "rm -rf ./.electrify/.dist && mkdir -p ./.electrify/.dist",
    "cleanDist:linux": "rm -rf ./.electrify/.dist && mkdir -p ./.electrify/.dist",
    "win:remove_dist": "if exist .electrify\\.dist rmdir /s /q .electrify\\.dist",
    "win:create_dist": "if not exist .electrify\\.dist mkdir .electrify\\.dist",
    "electron": "electrify",
    "releaseready": "meteor lint",
    "acquire:node": "cp \"$(which node)\" .electrify/bin/node",
    "build": "npm run cleanDist && run-script-os",
    "build:darwin": "npm run cleanDist:darwin && electrify package -o .electrify/.dist/ && node .scripts/harden-electron-package.js --platform=darwin",
    "build:linux": "npm run cleanDist:linux && electrify package -o .electrify/.dist/ && node .scripts/harden-electron-package.js --platform=linux",
    "build:win32": "npm run cleanDist && electrify package -o .electrify/.dist/ && node .scripts/harden-electron-package.js --platform=win32",
    "installer": "run-script-os",
    "installer:darwin": "cd .electrify/.dist/QRLWallet-darwin-x64 && create-dmg QRLWallet.app",
    "installer:linux": "node build-deb.js",
    "installer:win32": "node build-msi.js",
    "desktop": "meteor-desktop"
  },
  "snyk": true
}
